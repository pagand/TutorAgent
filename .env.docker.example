# ============================================================
# .env.docker.example — copy to .env and fill in real values
# ============================================================

# --- Postgres (used by docker-compose to create the DB) ---
POSTGRES_USER=aitutor
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=aitutor_db

# DATABASE_URL is auto-constructed in docker-compose.yml from the vars above.
# Set it here only if you need to override (e.g. external managed DB).
# DATABASE_URL=postgresql+asyncpg://aitutor:change_me@db:5432/aitutor_db

# --- LLM Provider ---
LLM_PROVIDER=google
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL_NAME=gemini-2.5-flash-lite

# --- CORS (set to your CloudFront domain in production) ---
ALLOWED_ORIGIN=*

# --- Exam Timer (ms) ---
EXAM_DURATION_MS=1500000

# --- File Paths (inside container — do not change unless you update volumes) ---
QUESTION_CSV_FILE_PATH=evaluation/data/server_ready_questions.csv
PDF_PATH=evaluation/data/evaluation_source.pdf
